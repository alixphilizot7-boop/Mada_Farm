generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  EMPLOYEE
}

model FarmSettings {
  id            String   @id @default("singleton")
  farmStartDate DateTime
  mgaPerEur     Float    @default(4800)
  updatedAt     DateTime @updatedAt
}

model PlanYear {
  id               String @id @default(cuid())
  year             Int    @unique
  targetEggs       Int
  targetChicksSold Int
  targetRevenue    Float
  targetCosts      Float
  targetNetResult  Float
}

enum FlockStatus {
  ACTIVE
  SOLD_OUT
  CLOSED
}

enum InventoryType {
  FEED
  WATER
  SUPPLEMENT
  MEDICINE
  OTHER
}

enum HealthRecordType {
  ILLNESS
  VACCINATION
  TREATMENT
  CHECKUP
}

enum HealthOutcome {
  RECOVERED
  ONGOING
  DECEASED
}

enum ProductType {
  EGGS
  CHICKS
  CHICKEN
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum CashType {
  INCOME
  EXPENSE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  eggLogs       EggLog[]
  purchases     Purchase[]
  usages        Usage[]
  healthRecords HealthRecord[]
  mortalityLogs MortalityLog[]
  invoices      Invoice[]
  cashTxns      CashTransaction[]
  auditLogs     AuditLog[]
  capexItems    CapexItem[]
  chickHatches  ChickHatch[]
  dailyLogs     DailyLog[]
}

model Flock {
  id           String      @id @default(cuid())
  name         String
  breed        String?
  startDate    DateTime
  initialCount Int
  currentCount Int
  status       FlockStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  eggLogs       EggLog[]
  usages        Usage[]
  healthRecords HealthRecord[]
  mortalityLogs MortalityLog[]
  chickHatches  ChickHatch[]
  dailyLogs     DailyLog[]

  @@index([status])
}

model EggLog {
  id           String   @id @default(cuid())
  date         DateTime
  flockId      String
  flock        Flock    @relation(fields: [flockId], references: [id])
  wholeCount   Int
  brokenCount  Int      @default(0)
  notes        String?
  recordedById String
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())

  dailyLog DailyLog?

  @@index([date])
  @@index([flockId])
}

model ChickHatch {
  id            String   @id @default(cuid())
  date          DateTime
  eggsSet       Int
  chicksHatched Int
  flockId       String?
  flock         Flock?   @relation(fields: [flockId], references: [id])
  notes         String?
  recordedById  String
  recordedBy    User     @relation(fields: [recordedById], references: [id])
  createdAt     DateTime @default(now())

  @@index([date])
  @@index([flockId])
}

model InventoryItem {
  id           String        @id @default(cuid())
  name         String
  type         InventoryType
  unit         String
  currentStock Float         @default(0)
  reorderLevel Float         @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  purchases Purchase[]
  usages    Usage[]

  @@unique([name])
}

model Purchase {
  id           String        @id @default(cuid())
  date         DateTime
  itemId       String
  item         InventoryItem @relation(fields: [itemId], references: [id])
  quantity     Float
  unitCost     Float
  totalCost    Float
  supplier     String?
  notes        String?
  recordedById String
  recordedBy   User          @relation(fields: [recordedById], references: [id])
  createdAt    DateTime      @default(now())

  cashTxn CashTransaction?

  @@index([date])
}

model Usage {
  id           String        @id @default(cuid())
  date         DateTime
  itemId       String
  item         InventoryItem @relation(fields: [itemId], references: [id])
  flockId      String?
  flock        Flock?        @relation(fields: [flockId], references: [id])
  quantity     Float
  notes        String?
  recordedById String
  recordedBy   User          @relation(fields: [recordedById], references: [id])
  createdAt    DateTime      @default(now())

  dailyLog DailyLog?

  @@index([date])
}

model HealthRecord {
  id              String           @id @default(cuid())
  date            DateTime
  flockId         String
  flock           Flock            @relation(fields: [flockId], references: [id])
  type            HealthRecordType
  vaccinationType String?
  affectedCount   Int              @default(0)
  diagnosis       String?
  treatment       String?
  medicineUsed    String?
  cost            Float            @default(0)
  outcome         HealthOutcome    @default(ONGOING)
  notes           String?
  recordedById    String
  recordedBy      User             @relation(fields: [recordedById], references: [id])
  createdAt       DateTime         @default(now())

  cashTxn      CashTransaction?
  mortalityLog MortalityLog?
  dailyLog     DailyLog?

  @@index([date])
  @@index([flockId])
}

model MortalityLog {
  id             String        @id @default(cuid())
  date           DateTime
  flockId        String
  flock          Flock         @relation(fields: [flockId], references: [id])
  quantity       Int
  cause          String?
  notes          String?
  healthRecordId String?       @unique
  healthRecord   HealthRecord? @relation(fields: [healthRecordId], references: [id])
  recordedById   String
  recordedBy     User          @relation(fields: [recordedById], references: [id])
  createdAt      DateTime      @default(now())

  dailyLog DailyLog?

  @@index([date])
  @@index([flockId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  issueDate     DateTime
  dueDate       DateTime?
  status        InvoiceStatus @default(DRAFT)
  subtotal      Float
  tax           Float         @default(0)
  total         Float
  notes         String?
  paidAt        DateTime?
  createdById   String
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items   InvoiceItem[]
  cashTxn CashTransaction?

  @@index([status])
  @@index([issueDate])
}

model InvoiceItem {
  id          String      @id @default(cuid())
  invoiceId   String
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productType ProductType
  description String
  quantity    Float
  unitPrice   Float
  total       Float
}

model CashTransaction {
  id             String        @id @default(cuid())
  date           DateTime
  type           CashType
  category       String
  amount         Float
  amountAriary   Float?
  description    String?
  invoiceId      String?       @unique
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])
  purchaseId     String?       @unique
  purchase       Purchase?     @relation(fields: [purchaseId], references: [id])
  healthRecordId String?       @unique
  healthRecord   HealthRecord? @relation(fields: [healthRecordId], references: [id])
  capexItemId    String?       @unique
  capexItem      CapexItem?    @relation(fields: [capexItemId], references: [id])
  recordedById   String
  recordedBy     User          @relation(fields: [recordedById], references: [id])
  createdAt      DateTime      @default(now())

  dailyLog DailyLog?

  @@index([date])
  @@index([type])
}

enum CapexStatus {
  PLANNED
  ORDERED
  PURCHASED
  DEFERRED
}

model CapexItem {
  id              String      @id @default(cuid())
  category        String
  name            String
  specs           String?
  status          CapexStatus @default(PLANNED)
  plannedQuantity Float?
  plannedUnitCost Float?
  plannedTotal    Float?
  actualQuantity  Float?
  actualUnitCost  Float?
  actualTotal     Float?
  supplier        String?
  link            String?
  purchaseDate    DateTime?
  notes           String?
  createdById     String
  createdBy       User        @relation(fields: [createdById], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  cashTxn CashTransaction?

  @@index([category])
  @@index([status])
}

model AuditLog {
  id        String      @id @default(cuid())
  entity    String
  entityId  String
  action    AuditAction
  summary   String
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  createdAt DateTime    @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

enum TaskResponsible {
  ALIX
  COPINE
  EMPLOYEE
  LOCAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

model TaskGroup {
  id        String   @id @default(cuid())
  name      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@index([order])
}

model Task {
  id          String            @id @default(cuid())
  groupId     String
  group       TaskGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title       String
  responsible TaskResponsible[]
  status      TaskStatus        @default(TODO)
  priority    TaskPriority      @default(MEDIUM)
  period      String?
  dueDate     DateTime?
  notes       String?
  order       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([groupId])
  @@index([status])
  @@index([dueDate])
}

model DailyLog {
  id      String   @id @default(cuid())
  date    DateTime
  flockId String
  flock   Flock    @relation(fields: [flockId], references: [id])
  weather String?
  notes   String?

  eggsSold   Int?
  chicksSold Int?

  eggLogId String?  @unique
  eggLog   EggLog?  @relation(fields: [eggLogId], references: [id])

  mortalityLogId String?       @unique
  mortalityLog   MortalityLog? @relation(fields: [mortalityLogId], references: [id])

  usageId String? @unique
  usage   Usage?  @relation(fields: [usageId], references: [id])

  healthRecordId String?       @unique
  healthRecord   HealthRecord? @relation(fields: [healthRecordId], references: [id])

  cashTxnId String?          @unique
  cashTxn   CashTransaction? @relation(fields: [cashTxnId], references: [id])

  recordedById String
  recordedBy   User     @relation(fields: [recordedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([date])
  @@index([flockId])
}
